# Copia questo file in .env e valorizza con le tue chiavi.
# Solo variabili con prefisso EXPO_PUBLIC_ sono esposte al client:
# non mettere qui MAI chiavi segrete (OpenAI, Mapbox server-side, service_role key).
# Quelle vivono solo lato Supabase Edge Functions / secrets.

EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
